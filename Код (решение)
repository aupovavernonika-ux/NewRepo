bool isPlaza(const room& r) {
    int len = strlen(r.hotel_name);
    return len >= 5 && strcmp(r.hotel_name + len - 5, "Plaza") == 0;
}

void bubbleSort(room arr[], int n, bool (*less)(const room&, const room&)) {
    for (int i = 0; i < n - 1; ++i) {
        for (int j = 0; j < n - i - 1; ++j) {
            if (!less(arr[j], arr[j + 1])) {
                room t = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = t;
            }
        }
    }
}

bool byPrice(const room& a, const room& b) { return a.price < b.price; }
bool byNumber(const room& a, const room& b) { return a.room_number < b.room_number; }

void printRoom(const room& r) {
    cout << "Отель: " << r.hotel_name << ", №" << r.room_number << endl;
    cout << "Комфортность: ";
    switch (r.comfort) {
    case lux: cout << "люкс"; break;
    case semilux: cout << "полулюкс"; break;
    case standart: cout << "стандарт"; break;
    case econom: cout << "эконом"; break;
    }
    cout << ", количество человек: " << r.number_of_people << ", цена: " << r.price << "$.\n" << "Опции: ";
    printOptions(r.options);
    cout << endl;
}
void printRooms(const room arr[], int size) {
    if (size == 0) cout << "Нет номеров для отображения." << endl;
    else for (int i = 0; i < size; ++i) printRoom(arr[i]);
}

int filter(const room src[], int n, room dst[], bool (*pred)(const room&)) {
    int count = 0;
    for (int i = 0; i < n; ++i)
        if (pred(src[i])) dst[count++] = src[i];
    return count;
}

void printByNumber(const room arr[], int n, int num) {
    for (int i = 0; i < n; ++i)
        if (arr[i].room_number == num) {
            cout << "\nДанные номера " << num << ":\n";
            printRoom(arr[i]);
            return;
        }
    cout << "Номер " << num << " не найден.\n";
}

bool hasSeaView(const room& r) { return r.options.sea_view; }

void printThreeCheapest(const room arr[], int n) {
    if (n < 3) { cout << "Меньше трёх номеров.\n"; return; }
    cout << "\nТри самых дешёвых:\n";
    for (int i = 0; i < 3; ++i) {
        cout << i + 1 << ". Отель " << arr[i].hotel_name << ", №" << arr[i].room_number
            << ", цена " << arr[i].price << "$. Опции: ";
        printOptions(arr[i].options);
        cout << endl;
    }
}

void changeRoom(room arr[], int n, int num) {
    for (int i = 0; i < n; ++i) {
        if (arr[i].room_number == num) {
