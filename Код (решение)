            cin >> arr[i].options.sea_view;
            cout << "\nДанные успешно обновлены. Новая информация о номере:\n";
            printRoom(arr[i]);
            return;
        }
    }
    cout << "Номер " << num << " не найден.\n";
}

//ЗАДАНИЕ 1: чтение из myfile.txt (текстовый файл) 
void updateSeaViewFromFile(const char* filename, room arr[], int n) {
    ifstream fin(filename);
    if (!fin.is_open()) {
        cout << "Не удалось открыть файл " << filename << " для чтения.\n";
        return;
    }
    char name[50];
    int value;
    while (fin >> name >> value) {
        for (int i = 0; i < n; ++i) {
            if (strcmp(arr[i].hotel_name, name) == 0) {
                arr[i].options.sea_view = (value != 0);
                break;
            }
        }
    }
    fin.close();
    cout << "Данные о виде на море обновлены из файла " << filename << endl;
}

//ЗАДАНИЕ 2: запись/чтение бинарного файла 
void saveRoomsToBinary(const char* filename, const room arr[], int count) {
    ofstream fout(filename, ios::binary);
    if (!fout.is_open()) {
        cout << "Ошибка открытия файла " << filename << " для записи\n";
        return;
    }
    fout.write((const char*)(&count), sizeof(count));
    fout.write((const char*)(arr), count * sizeof(room));
    fout.close();
    cout << "Сохранено " << count << " записей в бинарный файл " << filename << endl;
}

int loadRoomsFromBinary(const char* filename, room arr[], int maxSize) {
    ifstream fin(filename, ios::binary);
    if (!fin.is_open()) {
        cout << "Ошибка открытия файла " << filename << " для чтения\n";
        return 0;
    }
    int count = 0;
    fin.read((char*)(&count), sizeof(count));
    if (count > maxSize) {
        cout << "Предупреждение: в файле " << count << " записей, массив вмещает только " << maxSize << ". Будет загружено " << maxSize << " записей.\n";
        count = maxSize;
    }
    fin.read((char*)(arr), count * sizeof(room));
    fin.close();
    cout << "Загружено " << count << " записей из бинарного файла " << filename << endl;
    return count;
}

